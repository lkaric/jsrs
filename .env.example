# ============================================================
# JSRS — Environment Variables
# Copy this file to .env.local and fill in real values.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Local (Docker Compose):
DATABASE_URL="postgresql://jsrs:jsrs_dev_password@localhost:5432/jsrs_dev"
# Production (Neon): replace with your Neon connection string
# DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ── Auth (better-auth) ────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-32-byte-secret"
BETTER_AUTH_URL="http://localhost:3000"

# ── OAuth — GitHub ────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── OAuth — Google ────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@jsrs.dev"

# ── svc-verify (internal) ─────────────────────────────────────
# Shared HMAC secret between web app and svc-verify
# Generate with: openssl rand -hex 32
SVC_VERIFY_HMAC_SECRET="replace-with-64-char-hex"
SVC_VERIFY_URL="http://localhost:3001"

# ── svc-verify service (consumed by svc-verify itself) ────────
# Same value as SVC_VERIFY_HMAC_SECRET
VERIFY_HMAC_SECRET="replace-with-64-char-hex"
PORT="3001"

# ── ZKP Circuit Artifacts ─────────────────────────────────────
# Path to semaphore.wasm and semaphore.zkey
# These are downloaded separately — see packages/zkp-core/README.md
ZKP_ARTIFACTS_PATH="./packages/zkp-core/src/circuits"
